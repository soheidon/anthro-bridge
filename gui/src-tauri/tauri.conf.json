{
  "productName": "Anthropic Provider Gateway Manager",
  "version": "0.5.0",
  "identifier": "com.anthropic.provider-gateway-gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "licenseFile": "../../LICENSE",
    "resources": [
      "resources/config.json"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Anthropic Provider Gateway Manager",
        "width": 1100,
        "height": 680,
        "minWidth": 900,
        "minHeight": 580,
        "resizable": true
      }
    ]
  }
}
